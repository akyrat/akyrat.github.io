---
import { site } from "../../data/site";
---

<section id="contact" class="section contact">
  <div class="container">
    <p class="contact__heading">{site.contact.heading}</p>
    <p class="contact__sub">{site.contact.sub}</p>

    <nav class="contact__links" aria-label="Contact links">
      <a href={site.links.github} target="_blank" rel="noreferrer">GitHub</a>
      <a href={site.links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      {site.email && <a href={`mailto:${site.email}`}>Email</a>}
    </nav>
  </div>
</section>

<style>
  .contact .container {
    text-align: center;
  }

  .contact__heading {
    font-size: var(--step-2);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .contact__sub {
    color: var(--text-muted);
    font-size: var(--step-1);
    max-width: 42ch;
    margin-inline: auto;
    margin-bottom: var(--space-xl);
  }

  .contact__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
    font-weight: 600;
  }
</style>
