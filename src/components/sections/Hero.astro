---
import { site } from "../../data/site";
---

<header class="hero">
  <div class="container hero__inner">
    <div class="hero__text">
      <p class="hero__eyebrow">Portfolio</p>
      <h1 class="hero__name">{site.name}</h1>
      <p class="hero__role">{site.role}</p>
      <p class="hero__tagline">{site.tagline}</p>
      <div class="hero__cta">
        <a class="btn btn--primary" href="#timeline">View the timeline</a>
        <a class="btn" href="#about">About me</a>
      </div>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-block-size: 92svh;
    display: grid;
    align-items: center;
    overflow: hidden;
  }

  .hero__inner {
    padding-block: var(--space-3xl);
  }

  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-md);
  }

  .hero__name {
    font-size: var(--step-4);
    line-height: 1;
    margin-bottom: var(--space-sm);
    background: linear-gradient(180deg, var(--text) 60%, var(--text-muted));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__role {
    font-size: var(--step-2);
    font-weight: 600;
    color: var(--accent-bright);
    margin-bottom: var(--space-lg);
  }

  .hero__tagline {
    max-width: 38ch;
    color: var(--text-muted);
    font-size: var(--step-1);
    margin-bottom: var(--space-xl);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-weight: 600;
    font-size: var(--step--1);
    padding: 0.7rem 1.3rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    color: var(--text);
    transition:
      transform var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }

  .btn:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    color: var(--text);
  }

  .btn--primary {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
    box-shadow: 0 8px 26px -10px var(--accent-glow);
  }

  .btn--primary:hover {
    background: var(--accent-bright);
    color: var(--bg);
  }

  @media (max-width: 820px) {
    .hero__inner {
      padding-block: var(--space-2xl);
    }
  }
</style>
